# ===== Data source (DataForSEO) =====
# Sign up at https://dataforseo.com and find your credentials in the API settings
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_api_password

# ===== Alternative search (Tavily, optional) =====
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxx

# Which data source to use: "dataforseo" or "tavily"
DATA_SOURCE=dataforseo

# ===== Auth =====
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_long_random_string

# ===== Database (Turso - SQLite cloud, for Vercel) =====
# Get these from https://turso.tech after creating a database
# Local dev falls back to local SQLite if these are empty.
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJ_your_auth_token_here
